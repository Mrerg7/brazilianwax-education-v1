---
import { ACQUISITION_MAILTO, DISCLAIMER_DATE, SITE } from '../config/site';
---

<footer class="bg-white border-t border-[#EDE4D7]">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <!-- Sophisticated Domain Acquisition CTA -->
    <div
      class="relative overflow-hidden rounded-3xl border border-[#B85C38]/20 bg-gradient-to-br from-[#2D2D2D] via-[#1a1a1a] to-[#B85C38]/15 p-8 sm:p-12 mb-12"
    >
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-[#B85C38]/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-[#A04E30]/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 grid lg:grid-cols-[1.2fr_0.8fr] gap-10 items-center">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-[#B85C38] font-extrabold mb-4">
            Domain Available for Acquisition
          </p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight text-white mb-4">
            brazilianwax.education — A Category-Defining Education Asset
          </h2>
          <p class="text-white/60 max-w-xl leading-relaxed">
            Positioned at the intersection of professional beauty training, high-intent search
            keywords, and the trusted .education TLD, this domain is a rare strategic asset for
            academies, course platforms, and certification programs. Serious buyers may inquire for
            pricing, transfer logistics, and escrow options.
          </p>
        </div>

        <div
          class="rounded-2xl p-6 sm:p-8 border border-white/10 bg-black/40 backdrop-blur-xl"
        >
          <p class="text-xs uppercase tracking-[2px] text-white/40 font-semibold mb-2">
            Acquisition Contact
          </p>
          <a
            href={`mailto:${SITE.email}`}
            class="block text-2xl sm:text-3xl font-display text-white hover:text-[#B85C38] transition-colors break-all"
          >
            {SITE.email}
          </a>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-6 inline-flex w-full items-center justify-center gap-x-3 px-6 py-4 bg-gradient-to-r from-[#B85C38] to-[#A04E30] text-white font-extrabold rounded-2xl hover:brightness-110 transition-all"
          >
            <span>Inquire About Acquisition</span>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
          <p class="mt-4 text-[11px] text-white/40 text-center tracking-wide">
            Confidential inquiries &bull; Response within 24 hours
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-xs text-[#6B6B6B] leading-relaxed max-w-4xl mb-10">
      This website is for demonstration and informational purposes only. It does not constitute an
      offer of services, a commitment to deploy, or a guarantee of outcomes. All statistics,
      projections, and references to specific technologies are based on publicly available
      information as of {DISCLAIMER_DATE} and are subject to change.
    </p>

    <!-- Bottom bar -->
    <div
      class="pt-8 border-t border-[#EDE4D7] text-xs text-[#6B6B6B] flex flex-col md:flex-row gap-y-4 items-center justify-between"
    >
      <div>brazilianwax.education is a premium domain currently available for acquisition.</div>
      <div>Perfect for training academies &bull; Strong SEO &bull; High conversion potential</div>
    </div>
  </div>
</footer>
