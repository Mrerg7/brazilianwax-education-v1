---
import { getCollection } from 'astro:content';

const modules = (await getCollection('training')).sort((a, b) => a.data.order - b.data.order);
---

<section id="training" class="bg-white border-y border-[#EDE4D7]">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <div class="text-center mb-12">
      <div class="modern-pill inline-block mb-3">COMPREHENSIVE CURRICULUM</div>
      <h2 class="section-header tracking-tight">Master Epilation &amp; Launch Your Business</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {
        modules.map(({ data }) => (
          <div>
            <h3 class="font-semibold text-xl mb-4">{data.title}</h3>
            <ul class="space-y-3 text-[#5C5C5C]">
              {data.items.map((item) => (
                <li class="flex items-start gap-x-3">
                  <i class="fa-solid fa-check text-[#B85C38] mt-1" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
