---
import { cfImageUrl, CF_IMAGES } from '../config/site';

const heroImage = cfImageUrl(CF_IMAGES.heroImageId);
---

<header class="relative overflow-hidden">
  <div
    class="absolute inset-0 z-0"
    style={`
      background-image: url('${heroImage}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    `}
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 z-[1] bg-gradient-to-b from-black/40 via-black/20 to-[#F8F1E9]"
    aria-hidden="true"
  ></div>

  <div class="relative z-[2] max-w-5xl mx-auto px-6 pt-20 pb-16 md:pt-24 md:pb-20 text-center">
    <div class="inline-flex items-center gap-x-2 mb-6">
      <div
        class="modern-pill flex items-center gap-x-2 px-4 py-1 rounded-2xl text-xs font-bold tracking-[1px]"
      >
        <i class="fa-solid fa-graduation-cap fa-xs"></i>
        <span>PROFESSIONAL TRAINING • BUSINESS STARTUP</span>
      </div>
    </div>

    <h1 class="domain-name tracking-tighter mb-4 text-white drop-shadow-sm">brazilianwax.education</h1>

    <p
      class="max-w-2xl mx-auto text-2xl md:text-3xl font-semibold tracking-tight text-white/95 mb-5"
    >
      The definitive domain for Brazilian waxing<br class="hidden md:block" />training and business education.
    </p>

    <p class="max-w-md mx-auto text-lg text-white/80 mb-10">
      Master the art of epilation and gain the skills to launch your own profitable Brazilian waxing
      business.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#acquire"
        class="group inline-flex items-center justify-center gap-x-3 px-9 py-4 bg-[#B85C38] hover:bg-[#A04E30] text-white font-semibold text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-[#B85C38]/20"
      >
        <span>Inquire to Acquire</span>
        <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
      </a>

      <a
        href="#market"
        class="inline-flex items-center justify-center px-8 py-4 border border-white/40 hover:bg-white/10 text-white font-semibold text-lg rounded-3xl transition-all"
      >
        See the Opportunity
      </a>
    </div>
  </div>
</header>
