---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<section id="acquire" class="bg-[#2D2D2D] text-white">
  <div class="max-w-4xl mx-auto px-6 py-20 text-center">
    <div class="max-w-xl mx-auto">
      <div
        class="inline-block px-4 py-1 bg-white/10 rounded-full text-xs font-medium tracking-wider mb-6"
      >
        PREMIUM EDUCATION DOMAIN
      </div>

      <h2 class="text-5xl md:text-[3rem] font-semibold tracking-tighter leading-none mb-6">
        Own the definitive name for<br />Brazilian waxing education.
      </h2>

      <p class="text-xl text-white/70 mb-10">
        brazilianwax.education is the perfect domain for a professional training academy that
        combines expert epilation instruction with practical business startup skills. Capture the
        growing demand in one of the beauty industry's most profitable niches.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex items-center justify-center gap-x-3 px-10 py-4 bg-white text-[#2D2D2D] hover:bg-[#F8F1E9] font-semibold text-lg rounded-3xl transition-all active:scale-[0.985]"
        >
          <span>Make an Offer</span>
          <i class="fa-solid fa-envelope"></i>
        </a>

        <button
          id="copy-email-btn"
          type="button"
          class="inline-flex items-center justify-center gap-x-3 px-8 py-4 border border-white/30 hover:bg-white/5 font-medium text-lg rounded-3xl transition-all"
        >
          <span id="copy-btn-text">Copy Contact Email</span>
        </button>
      </div>

      <p class="mt-8 text-sm text-white/50">
        Serious inquiries only. This is a high-value strategic education domain.
      </p>
    </div>
  </div>
</section>

<script define:vars={{ email: SITE.email }}>
  function copyEmail() {
    navigator.clipboard
      .writeText(email)
      .then(() => {
        const btn = document.getElementById('copy-btn-text');
        if (btn) {
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => {
            btn.textContent = original;
          }, 2000);
        }
      })
      .catch(() => {
        window.location.href = `mailto:${email}`;
      });
  }
  document.getElementById('copy-email-btn')?.addEventListener('click', copyEmail);
</script>
